{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "dogz:german_shepherd",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/german_shepherd/tamed",
        "wild": "textures/entity/german_shepherd/wild"
      },
      "geometry": {
        "default": "geometry.dog_german_shepherd"
      },
      "animations": {
        "walk": "animation.retriever.walk",
        "sit": "animation.retriever.sit",
        "lay_down": "animation.retriever.lay_down",
        "look": "animation.common.look_at_target",
        "tail_health": "animation.retriever.tail_health"
      },
      "scripts": {
        "animate": [
          "look",
          { "walk": "query.modified_move_speed > 0.1 && !query.is_sitting" },
          { "sit": "query.is_sitting && !query.is_sheared" },
          { "lay_down": "query.is_sheared" },
          { "tail_health": "query.is_tamed" }
        ]
      },
      "render_controllers": [
        "controller.render.dog"
      ],
      "spawn_egg": {
        "base_color": "#a87a4f",
        "overlay_color": "#2c1c14"
      }
    }
  }
}
