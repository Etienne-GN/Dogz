{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "dogz:malamute",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/malamute/tamed",
        "wild": "textures/entity/malamute/wild"
      },
      "geometry": {
        "default": "geometry.dog_malamute"
      },
      "animations": {
        "walk": "animation.malamute.walk",
        "sit": "animation.malamute.sit",
        "lay_down": "animation.malamute.lay_down",
        "look": "animation.common.look_at_target",
        "tail_health": "animation.malamute.tail_health"
      },
      "scripts": {
        "animate": [
          "look",
          { "walk": "query.modified_move_speed > 0.1 && !query.is_sitting" },
          { "sit": "query.is_sitting && !query.is_sheared" },
          { "lay_down": "query.is_sheared" },
          { "tail_health": "query.is_tamed" }
        ]
      },
      "render_controllers": [
        "controller.render.dog"
      ],
      "spawn_egg": {
        "base_color": "#8B7355",
        "overlay_color": "#F0EAD6"
      }
    }
  }
}
