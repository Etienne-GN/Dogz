{
  "format_version": "1.8.0",
  "animations": {
    "animation.malamute.walk": {
      "loop": true,
      "bones": {
        "leg0": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg1": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17 + 180) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg2": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17 + 180) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg3": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "tail": { "rotation": [ 0, "math.cos(query.modified_distance_moved * 38.17) * 20 - this", 0 ] }
      }
    },
    "animation.malamute.sit": {
      "loop": true,
      "bones": {
        "body": {
          "rotation": [ "45.0 - this", 0, 0 ],
          "position": [ "-this", "-18 - this", "-this" ]
        },
        "upperBody": {
          "rotation": [ "72 - this", "-this", 0 ],
          "position": [ "-1.0 - this", "-16 - this", "-3.0 - this" ]
        },
        "leg0": {
          "rotation": [ "270 - this", 0, 0 ],
          "position": [ "-2.5 - this", "-22 - this", "2 - this" ]
        },
        "leg1": {
          "rotation": [ "270 - this", 0, 0 ],
          "position": [ "0.5 - this", "-22 - this", "2 - this" ]
        },
        "leg2": {
          "rotation": [ "333 - this", 0, 0 ],
          "position": [ "-2.49 - this", "-17 - this", "-4 - this" ]
        },
        "leg3": {
          "rotation": [ "333 - this", 0, 0 ],
          "position": [ "0.51 - this", "-17 - this", "-4 - this" ]
        },
        "tail": { "position": [ "-1.0 - this", "-20 - this", "4 - this" ] }
      }
    },
    "animation.malamute.lay_down": {
      "loop": true,
      "bones": {
        "body": { "position": [ "-this", "-22 - this", "-this" ] },
        "head": { "rotation": [ "15 - this", 0, 0 ] },
        "leg0": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "-2.5 - this", "-22 - this", "2 - this" ]
        },
        "leg1": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "0.5 - this", "-22 - this", "2 - this" ]
        },
        "leg2": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "-2.49 - this", "-18 - this", "-4 - this" ]
        },
        "leg3": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "0.51 - this", "-18 - this", "-4 - this" ]
        },
        "tail": { "position": [ "-1.0 - this", "-22 - this", "4 - this" ] }
      }
    },
    "animation.malamute.tail_health": {
      "loop": true,
      "bones": {
        "tail": {
          "rotation": [ "math.lerp(-27.0, 63.0, query.health / query.max_health) - this", 0, 0 ]
        }
      }
    }
  }
}
