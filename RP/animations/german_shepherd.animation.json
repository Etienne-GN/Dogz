{
  "format_version": "1.8.0",
  "animations": {
    "animation.german_shepherd.walk": {
      "loop": true,
      "bones": {
        "leg0blood": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg1blood": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17 + 180) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg2blood": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17 + 180) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "leg3blood": { "rotation": [ "math.cos(query.modified_distance_moved * 38.17) * 80.22 * query.modified_move_speed - this", 0, 0 ] },
        "tail3": { "rotation": [ 0, "math.cos(query.modified_distance_moved * 38.17) * 20 - this", 0 ] }
      }
    },
    "animation.german_shepherd.sit": {
      "loop": true,
      "bones": {
        "body": {
          "rotation": [ "45.0 - this", 0, 0 ],
          "position": [ "-this", "-18 - this", "-this" ]
        },
        "leg0blood": {
          "rotation": [ "270 - this", 0, 0 ],
          "position": [ "-3.0 - this", "-22 - this", "3.5 - this" ]
        },
        "leg1blood": {
          "rotation": [ "270 - this", 0, 0 ],
          "position": [ "1.0 - this", "-22 - this", "3.5 - this" ]
        },
        "leg2blood": {
          "rotation": [ "333 - this", 0, 0 ],
          "position": [ "-3.0 - this", "-17 - this", "-5.5 - this" ]
        },
        "leg3blood": {
          "rotation": [ "333 - this", 0, 0 ],
          "position": [ "1.0 - this", "-17 - this", "-5.5 - this" ]
        },
        "tail3": { "position": [ "-this", "-20 - this", "-this" ] }
      }
    },
    "animation.german_shepherd.lay_down": {
      "loop": true,
      "bones": {
        "body": { "position": [ "-this", "-22 - this", "-this" ] },
        "heads": { "rotation": [ "15 - this", 0, 0 ] },
        "leg0blood": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "-3.0 - this", "-22 - this", "3.5 - this" ]
        },
        "leg1blood": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "1.0 - this", "-22 - this", "3.5 - this" ]
        },
        "leg2blood": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "-3.0 - this", "-18 - this", "-5.5 - this" ]
        },
        "leg3blood": {
          "rotation": [ "300 - this", 0, 0 ],
          "position": [ "1.0 - this", "-18 - this", "-5.5 - this" ]
        },
        "tail3": { "position": [ "-this", "-22 - this", "-this" ] }
      }
    },
    "animation.german_shepherd.tail_health": {
      "loop": true,
      "bones": {
        "tail3": {
          "rotation": [ "math.lerp(-27.0, 63.0, query.health / query.max_health) - this", 0, 0 ]
        }
      }
    }
  }
}
