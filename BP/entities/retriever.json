{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "dogz:retriever",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "dogz:wild": {
        "minecraft:tameable": {
          "probability": 0.33,
          "tame_items": [ "bone" ],
          "tame_event": { "event": "minecraft:on_tame", "target": "self" }
        },
        "minecraft:behavior.tempt": {
          "priority": 4, "speed_multiplier": 1.2,
          "items": [ "bone", "beef", "cooked_beef", "chicken", "cooked_chicken", "porkchop", "cooked_porkchop", "muttonRaw", "muttonCooked", "rabbit", "cooked_rabbit", "rotten_flesh" ]
        },
        "minecraft:behavior.random_stroll": { "priority": 7, "speed_multiplier": 0.8 }
      },
      "dogz:alive": {
        "minecraft:health": { "value": 100, "max": 100 },
        "minecraft:damage_sensor": {
          "triggers": [
            {
              "on_damage": {
                "filters": { "test": "is_family", "subject": "self", "value": "dog" },
                "max_damage": 15
              }
            },
            {
              "on_damage": {
                "filters": { "test": "has_damage", "value": "fatal" },
                "event": "dogz:on_downed", "target": "self"
              },
              "deals_damage": false
            }
          ]
        }
      },
      "dogz:tamed_base": {
        "minecraft:is_tame": {},
        "minecraft:leashable": { "soft_distance": 2.0, "hard_distance": 4.0, "max_distance": 10.0 },
        "minecraft:breedable": {
          "require_tame": true,
          "breeds_with": [ { "mate_type": "dogz:retriever", "baby_type": "dogz:retriever", "breed_items": [ "beef", "cooked_beef", "chicken", "cooked_chicken", "porkchop", "cooked_porkchop" ] } ]
        },
        "minecraft:healable": {
          "items": [
            { "item": "beef", "heal_amount": 2 }, { "item": "cooked_beef", "heal_amount": 4 },
            { "item": "chicken", "heal_amount": 2 }, { "item": "cooked_chicken", "heal_amount": 4 },
            { "item": "porkchop", "heal_amount": 2 }, { "item": "cooked_porkchop", "heal_amount": 4 },
            { "item": "muttonRaw", "heal_amount": 2 }, { "item": "muttonCooked", "heal_amount": 4 },
            { "item": "rabbit", "heal_amount": 2 }, { "item": "cooked_rabbit", "heal_amount": 4 },
            { "item": "rotten_flesh", "heal_amount": 2 }
          ]
        },
        "minecraft:entity_sensor": {
          "sensor_range": 16.0, "relative_range": false, "require_all": false,
          "event": "dogz:bark_start",
          "event_filters": {
            "all_of": [
              { "any_of": [ { "test": "is_family", "subject": "other", "value": "monster" }, { "test": "is_family", "subject": "other", "value": "creeper" } ] },
              { "test": "has_component", "subject": "self", "operator": "!=", "value": "minecraft:is_sheared" },
              { "test": "has_component", "subject": "self", "operator": "!=", "value": "minecraft:is_baby" },
              { "test": "has_component", "subject": "self", "operator": "!=", "value": "minecraft:is_stunned" },
              { "test": "has_component", "subject": "self", "operator": "!=", "value": "minecraft:is_shaking" }
            ]
          }
        }
      },
      "dogz:standing_interact": {},
      "dogz:sitting_interact": {},
      "dogz:laying_interact": {},
      "dogz:attack_ai": {
        "minecraft:behavior.owner_hurt_by_target": { "priority": 1 },
        "minecraft:behavior.owner_hurt_target": { "priority": 2 },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4, "must_see": true,
          "entity_types": [
            {
              "filters": {
                "all_of": [
                  { "test": "is_family", "subject": "other", "value": "monster" },
                  { "test": "is_family", "subject": "other", "operator": "!=", "value": "creeper" }
                ]
              },
              "max_dist": 16
            }
          ]
        },
        "minecraft:behavior.melee_attack": { "priority": 3 }
      },
      "dogz:movement_active": {
        "minecraft:movement": { "value": 0.3 },
        "minecraft:navigation.walk": { "can_path_over_water": true, "avoid_damage_blocks": true, "can_jump": true }
      },
      "dogz:follow_ai": {
        "minecraft:behavior.follow_owner": { "priority": 6, "speed_multiplier": 1.5, "start_distance": 5.0, "stop_distance": 2.0 },
        "minecraft:behavior.random_stroll": { "priority": 7, "speed_multiplier": 0.8 }
      },
      "dogz:sitting": {
        "minecraft:is_baby": {},
        "minecraft:sittable": { "sit_event": { "event": "dogz:on_sit", "target": "self" }, "stand_event": { "event": "dogz:on_stand", "target": "self" } },
        "minecraft:behavior.stay_while_sitting": { "priority": 1 }
      },
      "dogz:laying": {
        "minecraft:is_baby": {},
        "minecraft:is_sheared": {},
        "minecraft:sittable": { "sit_event": { "event": "dogz:on_sit", "target": "self" }, "stand_event": { "event": "dogz:on_stand", "target": "self" } },
        "minecraft:behavior.stay_while_sitting": { "priority": 1 }
      },
      "dogz:barking_state": {
        "minecraft:is_stunned": {},
        "minecraft:type_family": { "family": [ "wolf", "dog", "mob", "barking", "cat", "ocelot" ] }
      },
      "dogz:bark_phase_1": {
        "minecraft:timer": { "time": 0.25, "time_down_event": { "event": "dogz:bark_2", "target": "self" } }
      },
      "dogz:bark_phase_2": {
        "minecraft:timer": { "time": 0.25, "time_down_event": { "event": "dogz:bark_3", "target": "self" } }
      },
      "dogz:bark_cooldown": {
        "minecraft:timer": { "time": 3.0, "time_down_event": { "event": "dogz:bark_reset", "target": "self" } }
      },
      "dogz:guard_ai": {
        "minecraft:behavior.random_stroll": { "priority": 7, "speed_multiplier": 0.5 }
      },
      "dogz:downed": {
        "minecraft:is_shaking": {}, "minecraft:is_sheared": {}, "minecraft:is_baby": {},
        "minecraft:health": { "value": 1, "max": 100 },
        "minecraft:sittable": { "sit_event": { "event": "dogz:on_sit", "target": "self" }, "stand_event": { "event": "dogz:on_stand", "target": "self" } },
        "minecraft:behavior.stay_while_sitting": { "priority": 1 },
        "minecraft:movement": { "value": 0.0 },
        "minecraft:damage_sensor": { "triggers": [ { "deals_damage": false } ] },
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    { "test": "is_owner", "subject": "other", "value": true },
                    {
                      "any_of": [
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "beef" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "cooked_beef" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "chicken" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "cooked_chicken" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "porkchop" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "cooked_porkchop" },
                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "rotten_flesh" }
                      ]
                    }
                  ]
                },
                "event": "dogz:on_revived", "target": "self"
              },
              "use_item": true, "play_sounds": "eat", "interact_text": "action.interact.revive"
            }
          ]
        },
        "minecraft:timer": { "time": [ 3.0, 6.0 ], "looping": true, "time_down_event": { "event": "dogz:play_whine", "target": "self" } }
      }
    },
    "components": {
      "minecraft:type_family": { "family": [ "wolf", "dog", "mob", "cat", "ocelot" ] },
      "minecraft:nameable": { "always_show": false, "allow_name_tag_renaming": true },
      "minecraft:attack": { "damage": 4 },
      "minecraft:movement.basic": {}, "minecraft:jump.static": {}, "minecraft:can_climb": {}, "minecraft:physics": {}, "minecraft:pushable": { "is_pushable": true },
      "minecraft:collision_box": { "width": 0.6, "height": 0.85 },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.look_at_player": { "priority": 8, "look_distance": 8.0 },
      "minecraft:behavior.random_look_around": { "priority": 9 },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "on_damage": {
              "filters": { "all_of": [ { "test": "is_tame" }, { "test": "has_component", "subject": "self", "operator": "==", "value": "minecraft:is_baby" } ] },
              "deals_damage": false
            }
          }
        ]
      }
    },
    "events": {
      "minecraft:entity_spawned": { "add": { "component_groups": [ "dogz:wild", "dogz:alive", "dogz:movement_active" ] } },
      "minecraft:on_tame": {
        "remove": { "component_groups": [ "dogz:wild" ] },
        "add": { "component_groups": [ "dogz:tamed_base", "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact" ] }
      },
      "dogz:on_sit": {
        "remove": { "component_groups": [ "dogz:follow_ai", "dogz:laying", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact", "dogz:laying_interact" ] },
        "add": { "component_groups": [ "dogz:sitting", "dogz:sitting_interact" ] }
      },
      "dogz:on_stand": {
        "remove": { "component_groups": [ "dogz:sitting", "dogz:laying", "dogz:sitting_interact", "dogz:laying_interact" ] },
        "add": { "component_groups": [ "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact" ] }
      },
      "dogz:lay_down": {
        "remove": { "component_groups": [ "dogz:follow_ai", "dogz:sitting", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact", "dogz:sitting_interact" ] },
        "add": { "component_groups": [ "dogz:laying", "dogz:laying_interact" ] }
      },
      "dogz:stand_up": {
        "remove": { "component_groups": [ "dogz:laying", "dogz:sitting", "dogz:laying_interact", "dogz:sitting_interact" ] },
        "add": { "component_groups": [ "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact" ] }
      },
      "minecraft:on_heal": {
        "remove": { "component_groups": [ "dogz:sitting", "dogz:laying", "dogz:sitting_interact", "dogz:laying_interact" ] },
        "add": { "component_groups": [ "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact" ] }
      },
      "dogz:bark_start": {
        "add": { "component_groups": [ "dogz:barking_state", "dogz:bark_phase_1" ] },
        "queue_command": { "command": [ "playsound mob.wolf.bark @a ~ ~ ~ 0.5 1" ] }
      },
      "dogz:bark_2": {
        "remove": { "component_groups": [ "dogz:bark_phase_1" ] },
        "add": { "component_groups": [ "dogz:bark_phase_2" ] },
        "queue_command": { "command": [ "playsound mob.wolf.bark @a ~ ~ ~ 0.5 1" ] }
      },
      "dogz:bark_3": {
        "remove": { "component_groups": [ "dogz:bark_phase_2" ] },
        "add": { "component_groups": [ "dogz:bark_cooldown" ] },
        "queue_command": { "command": [ "playsound mob.wolf.bark @a ~ ~ ~ 0.5 1" ] }
      },
      "dogz:bark_reset": { "remove": { "component_groups": [ "dogz:barking_state", "dogz:bark_cooldown" ] } },
      "dogz:on_downed": {
        "remove": { "component_groups": [ "dogz:alive", "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact", "dogz:sitting_interact", "dogz:laying_interact", "dogz:sitting", "dogz:laying", "dogz:barking_state", "dogz:bark_phase_1", "dogz:bark_phase_2", "dogz:bark_cooldown" ] },
        "add": { "component_groups": [ "dogz:downed" ] },
        "queue_command": { "command": [ "playsound mob.wolf.whine @a ~ ~ ~ 1 1" ] }
      },
      "dogz:on_revived": {
        "remove": { "component_groups": [ "dogz:downed" ] },
        "add": { "component_groups": [ "dogz:alive", "dogz:follow_ai", "dogz:attack_ai", "dogz:movement_active", "dogz:standing_interact" ] },
        "queue_command": { "command": [ "playsound mob.wolf.bark @a ~ ~ ~ 1 1" ] }
      },
      "dogz:play_whine": { "queue_command": { "command": [ "playsound mob.wolf.whine @a ~ ~ ~ 0.5 1" ] } },
      "dogz:set_guard": { "remove": { "component_groups": [ "dogz:follow_ai" ] }, "add": { "component_groups": [ "dogz:guard_ai" ] } },
      "dogz:set_follow": { "remove": { "component_groups": [ "dogz:guard_ai" ] }, "add": { "component_groups": [ "dogz:follow_ai" ] } }
    }
  }
}