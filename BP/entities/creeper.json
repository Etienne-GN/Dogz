{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:creeper",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "minecraft:is_charged": {
        "minecraft:explode": {
          "fuse_length": 1.5,
          "fuse_lit": false,
          "power": 6,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        }
      },
      "minecraft:on_prime": {
        "minecraft:explode": {
          "fuse_length": 1.5,
          "fuse_lit": true,
          "power": 3,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        },
        "minecraft:movement": {
          "value": 0
        }
      },
      "minecraft:charged_on_prime": {
        "minecraft:explode": {
          "fuse_length": 1.5,
          "fuse_lit": true,
          "power": 6,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        },
        "minecraft:movement": {
          "value": 0
        }
      }
    },
    "components": {
      "minecraft:is_tamed": {
        "filters": { "test": "is_family", "subject": "other", "value": "never" }
      },
      "minecraft:type_family": {
        "family": [ "creeper", "monster", "mob" ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "dog" },
                { "test": "is_family", "subject": "other", "value": "barking" },
                { "test": "is_family", "subject": "other", "value": "ocelot" },
                { "test": "is_family", "subject": "other", "value": "cat" }
              ]
            },
            "max_dist": 16,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.2
          }
        ]
      },
      "minecraft:behavior.swell": {
        "priority": 2,
        "start_distance": 3.0,
        "stop_distance": 6.0
      },
      "minecraft:behavior.melee_attack": {
        "priority": 3
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 4,
        "entity_types": [
          {
            "filters": { "test": "is_family", "subject": "other", "value": "player" },
            "max_dist": 16
          }
        ]
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 5
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 8.0
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:explode": {
        "fuse_length": 1.5,
        "power": 3,
        "causes_fire": false,
        "destroy_affected_by_griefing": true
      }
    },
    "events": {
      "minecraft:start_exploding": {
        "add": { "component_groups": [ "minecraft:on_prime" ] }
      },
      "minecraft:stop_exploding": {
        "remove": { "component_groups": [ "minecraft:on_prime", "minecraft:charged_on_prime" ] }
      }
    }
  }
}
