{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:creeper",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "minecraft:creeper_forced_explode": {
        "minecraft:explode": {
          "fuse_length": 0,
          "fuse_lit": true,
          "power": 3,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        }
      },
      "minecraft:creeper_charged": {
        "minecraft:is_charged": {},
        "minecraft:explode": {
          "fuse_length": 1.5,
          "power": 6,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        }
      }
    },
    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:experience_reward": {
        "on_death_update_loot": true,
        "value": 5
      },
      "minecraft:type_family": {
        "family": [ "creeper", "monster", "mob" ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.7
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:follow_range": {
        "value": 16
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:explode": {
        "fuse_length": 1.5,
        "power": 3,
        "causes_fire": false,
        "destroy_affected_by_griefing": true
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "dog" },
                { "test": "is_family", "subject": "other", "value": "barking" },
                { "test": "is_family", "subject": "other", "value": "ocelot" },
                { "test": "is_family", "subject": "other", "value": "cat" }
              ]
            },
            "max_dist": 6,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.2
          }
        ]
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "entity_types": [
          {
            "filters": { "test": "is_family", "subject": "other", "value": "player" },
            "max_dist": 16
          }
        ]
      },
      "minecraft:behavior.swell": {
        "priority": 3,
        "start_distance": 2.5,
        "stop_distance": 6.0
      },
      "minecraft:behavior.move_to_target": {
        "priority": 4,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 5
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 8.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      }
    },
    "events": {
      "minecraft:become_charged": {
        "add": { "component_groups": [ "minecraft:creeper_charged" ] }
      },
      "minecraft:start_exploding_forced": {
        "add": { "component_groups": [ "minecraft:creeper_forced_explode" ] }
      }
    }
  }
}
