{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:creeper",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "minecraft:exploding": {
        "minecraft:explode": {
          "fuse_length": 1.5,
          "power": 3,
          "causes_fire": false,
          "destroy_affected_by_griefing": true
        },
        "minecraft:on_fire": {
          "on_fire_time": 30
        }
      }
    },
    "components": {
      "minecraft:is_tamed": { "filters": { "test": "is_family", "subject": "other", "value": "never" } },
      "minecraft:type_family": { "family": [ "creeper", "monster", "mob" ] },
      "minecraft:breathable": { "total_supply": 15, "suffocate_time": 0 },
      "minecraft:health": { "value": 20, "max": 20 },
      "minecraft:movement": { "value": 0.2 },
      "minecraft:navigation.walk": { "can_path_over_water": true, "avoid_damage_blocks": true },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:physics": {},
      "minecraft:pushable": { "is_pushable": true, "is_pushable_by_piston": true },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.swell": { "start_distance": 3.0, "stop_distance": 6.0 },
      "minecraft:behavior.melee_attack": { "priority": 3 },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 1,
        "entity_types": [
          {
            "filters": { "any_of": [ { "test": "is_family", "subject": "other", "value": "wolf" }, { "test": "is_family", "subject": "other", "value": "dog" }, { "test": "is_family", "subject": "other", "value": "ocelot" }, { "test": "is_family", "subject": "other", "value": "cat" } ] },
            "max_dist": 16,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.2
          }
        ]
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "entity_types": [ { "filters": { "test": "is_family", "subject": "other", "value": "player" }, "max_dist": 16 } ]
      },
      "minecraft:behavior.random_stroll": { "priority": 4, "speed_multiplier": 1.0 },
      "minecraft:behavior.look_at_player": { "priority": 5, "look_distance": 8.0 },
      "minecraft:behavior.random_look_around": { "priority": 6 },
      "minecraft:explode": { "fuse_length": 1.5, "power": 3, "causes_fire": false, "destroy_affected_by_griefing": true }
    },
    "events": {
      "minecraft:start_exploding": { "add": { "component_groups": [ "minecraft:exploding" ] } },
      "minecraft:stop_exploding": { "remove": { "component_groups": [ "minecraft:exploding" ] } }
    }
  }
}
