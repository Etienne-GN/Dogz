{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:creeper",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "minecraft:forced_to_swell": {
        "minecraft:movement": { "value": 0 },
        "minecraft:behavior.swell": { "priority": 1, "start_distance": 2.5, "stop_distance": 6.0 }
      },
      "minecraft:is_charged": {
        "minecraft:explode": {
          "fuse_length": 1.5, "fuse_lit": false, "power": 6,
          "cause_fire": false, "destroy_affected_by_griefing": true
        }
      },
      "minecraft:on_prime": {
        "minecraft:explode": {
          "fuse_length": 1.5, "fuse_lit": true, "power": 3,
          "cause_fire": false, "destroy_affected_by_griefing": true
        },
        "minecraft:movement": { "value": 0 }
      },
      "minecraft:charged_on_prime": {
        "minecraft:explode": {
          "fuse_length": 1.5, "fuse_lit": true, "power": 6,
          "cause_fire": false, "destroy_affected_by_griefing": true
        },
        "minecraft:movement": { "value": 0 }
      }
    },
    "components": {
      "minecraft:type_family": { "family": [ "creeper", "monster", "mob" ] },
      "minecraft:health": { "value": 20, "max": 20 },
      "minecraft:loot": { "table": "loot_tables/entities/creeper.json" },
      "minecraft:attack": { "damage": 3 },
      "minecraft:movement": { "value": 0.25 },
      "minecraft:movement.basic": {},
      "minecraft:navigation.walk": {
        "can_path_over_water": false,
        "avoid_water": true,
        "avoid_damage_blocks": true,
        "can_jump": true
      },
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:physics": {},
      "minecraft:pushable": { "is_pushable": true, "is_pushable_by_piston": true },
      "minecraft:collision_box": { "width": 0.6, "height": 1.7 },
      "minecraft:nameable": {},
      "minecraft:leashable": { "soft_distance": 4.0, "hard_distance": 6.0, "max_distance": 10.0 },
      "minecraft:explode": {
        "fuse_length": 1.5, "fuse_lit": false, "power": 3,
        "cause_fire": false, "destroy_affected_by_griefing": true
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "on_damage": {
              "filters": { "test": "is_family", "subject": "damager", "value": "lightning" },
              "event": "minecraft:become_charged"
            },
            "deals_damage": false
          }
        ]
      },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 2,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "dog" },
                { "test": "is_family", "subject": "other", "value": "ocelot" },
                { "test": "is_family", "subject": "other", "value": "cat" }
              ]
            },
            "max_dist": 8,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.2
          }
        ]
      },
      "minecraft:behavior.swell": { "priority": 4, "start_distance": 2.5, "stop_distance": 6.0 },
      "minecraft:behavior.melee_attack": { "priority": 5, "speed_multiplier": 1.25, "track_target": false },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 6,
        "must_see": true,
        "reselect_targets": false,
        "entity_types": [
          {
            "filters": { "test": "is_family", "subject": "other", "value": "player" },
            "max_dist": 16
          }
        ]
      },
      "minecraft:behavior.hurt_by_target": { "priority": 7 },
      "minecraft:behavior.random_stroll": { "priority": 8, "speed_multiplier": 1.0 },
      "minecraft:behavior.look_at_player": { "priority": 9, "look_distance": 8.0 },
      "minecraft:behavior.random_look_around": { "priority": 10 }
    },
    "events": {
      "minecraft:entity_spawned": {},
      "minecraft:become_charged": {
        "remove": {},
        "add": { "component_groups": [ "minecraft:is_charged" ] }
      },
      "minecraft:start_exploding": {
        "add": { "component_groups": [ "minecraft:on_prime" ] }
      },
      "minecraft:start_exploding_forced": {
        "add": { "component_groups": [ "minecraft:forced_to_swell" ] }
      },
      "minecraft:stop_exploding": {
        "remove": { "component_groups": [ "minecraft:on_prime", "minecraft:charged_on_prime", "minecraft:forced_to_swell" ] }
      }
    }
  }
}
